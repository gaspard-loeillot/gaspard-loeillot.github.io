---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PodcastEpisode from '../components/PodcastEpisode.astro';

const episodes = (
  await getCollection('podcasts', ({ data }) => !data.draft)
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Podcasts"
  description="Conversations with founders, investors, and interesting people — by Gaspard Loeillot."
>
  <header class="mb-12">
    <h1 class="font-serif text-3xl leading-tight tracking-tight sm:text-4xl">
      Podcasts
    </h1>
    <p class="mt-3 text-[15px] leading-relaxed" style="color: var(--fg-muted);">
      Conversations with founders, investors, athletes, and anyone else worth
      sitting down with. Scope is broad — startups, life, sports, whatever
      we end up talking about.
    </p>
  </header>

  {
    episodes.length === 0 ? (
      <p class="text-[15px]" style="color: var(--fg-muted);">
        No episodes published yet.
      </p>
    ) : (
      <div>
        {episodes.map((episode) => (
          <PodcastEpisode episode={episode} />
        ))}
      </div>
    )
  }
</BaseLayout>
