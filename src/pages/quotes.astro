---
import BaseLayout from '../layouts/BaseLayout.astro';
import quotesData from '../data/quotes.json';

interface QuoteEntry {
  text: string;
  attribution: string;
  source?: string;
}

const quotes = quotesData as QuoteEntry[];
---

<BaseLayout
  title="Quotes"
  description="A curated, scrollable list of quotes I keep coming back to."
  variant="reading"
>
  <header class="mb-12">
    <h1 class="font-serif text-3xl leading-tight tracking-tight sm:text-4xl">
      Quotes
    </h1>
    <p class="mt-3 text-[15px] leading-relaxed" style="color: var(--fg-muted);">
      A running list of lines I keep coming back to — personal curation, not an
      anthology.
    </p>
  </header>

  <ul class="flex flex-col gap-10">
    {
      quotes.map((q) => (
        <li class="border-l-2 pl-5" style="border-color: var(--rule);">
          <blockquote class="font-serif text-lg leading-snug">
            &ldquo;{q.text}&rdquo;
          </blockquote>
          <footer
            class="ui mt-3 text-[13px]"
            style="color: var(--fg-muted);"
          >
            — {q.attribution}
            {q.source && (
              <span style="color: var(--fg-faint);">, {q.source}</span>
            )}
          </footer>
        </li>
      ))
    }
  </ul>

  {
    quotes.length === 0 && (
      <p class="text-[15px]" style="color: var(--fg-muted);">
        No quotes yet.
      </p>
    )
  }
</BaseLayout>
