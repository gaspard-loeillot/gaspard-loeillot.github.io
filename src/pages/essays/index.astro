---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EssayListItem from '../../components/EssayListItem.astro';

const essays = (await getCollection('essays', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

// Group by year for a Paul Graham–style archive.
const byYear = new Map<number, typeof essays>();
for (const essay of essays) {
  const y = essay.data.date.getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(essay);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<BaseLayout
  title="Essays"
  description="An archive of long-form essays by Gaspard Loeillot."
>
  <header class="mb-10">
    <h1 class="font-serif text-3xl leading-tight tracking-tight sm:text-4xl">
      Essays
    </h1>
    <p
      class="mt-3 text-[15px] leading-relaxed"
      style="color: var(--fg-muted);"
    >
      Long-form writing. I try to publish only what I'd want to re-read in a
      year.
    </p>
  </header>

  {
    years.map((year) => (
      <section class="mb-10">
        <h2
          class="ui mb-3 text-[11px] uppercase tracking-[0.2em]"
          style="color: var(--fg-faint);"
        >
          {year}
        </h2>
        <ul>
          {byYear.get(year)!.map((essay) => (
            <EssayListItem essay={essay} />
          ))}
        </ul>
      </section>
    ))
  }

  {
    essays.length === 0 && (
      <p class="text-[15px]" style="color: var(--fg-muted);">
        No essays published yet.
      </p>
    )
  }
</BaseLayout>
