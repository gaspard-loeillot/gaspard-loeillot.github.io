---
import type { CollectionEntry } from 'astro:content';

interface Props {
  essay: CollectionEntry<'essays'>;
}

const { essay } = Astro.props;
const { title, date, description, tags, coverImage } = essay.data;

const dateLabel = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a
  href={`/essays/${essay.id}/`}
  class="group block hover:no-underline"
>
  <article
    class="flex flex-col overflow-hidden rounded-lg border transition-colors"
    style="border-color: var(--rule); background: var(--bg-elevated);"
  >
    {
      coverImage && (
        <div
          class="aspect-[16/9] w-full overflow-hidden"
          style="background: var(--rule);"
        >
          <img
            src={coverImage}
            alt=""
            loading="lazy"
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
          />
        </div>
      )
    }
    <div class="flex flex-1 flex-col gap-3 p-5 sm:p-6">
      <div
        class="ui flex items-center gap-2 text-[11px] uppercase tracking-wider"
        style="color: var(--fg-faint);"
      >
        <time datetime={date.toISOString()}>{dateLabel}</time>
        {
          tags.length > 0 && (
            <>
              <span>·</span>
              <span class="flex flex-wrap gap-x-2">
                {tags.slice(0, 3).map((t) => (
                  <span>{t}</span>
                ))}
              </span>
            </>
          )
        }
      </div>
      <h3
        class="font-serif text-2xl leading-tight tracking-tight transition-colors group-hover:text-[var(--accent)]"
      >
        {title}
      </h3>
      {
        description && (
          <p
            class="text-[15px] leading-relaxed"
            style="color: var(--fg-muted);"
          >
            {description}
          </p>
        )
      }
    </div>
  </article>
</a>
