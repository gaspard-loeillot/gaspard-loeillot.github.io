---
/**
 * Minimal sun/moon toggle. Reads current state from the <html> class
 * (set before first paint in BaseLayout) and toggles + persists.
 */
---

<button
  type="button"
  id="theme-toggle"
  aria-label="Toggle color theme"
  class="flex h-7 w-7 items-center justify-center rounded-md opacity-70 transition-opacity hover:opacity-100"
>
  <svg
    id="theme-icon-sun"
    class="hidden"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
    ></path>
  </svg>
  <svg
    id="theme-icon-moon"
    class="hidden"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
  </svg>
</button>

<script>
  const btn = document.getElementById('theme-toggle');
  const sun = document.getElementById('theme-icon-sun');
  const moon = document.getElementById('theme-icon-moon');

  function sync() {
    const isDark = document.documentElement.classList.contains('dark');
    // In dark mode show the sun (action: switch to light); in light show the moon.
    sun?.classList.toggle('hidden', !isDark);
    moon?.classList.toggle('hidden', isDark);
  }

  sync();

  btn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    try {
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    } catch (_) {
      // ignore storage errors (private mode, etc.)
    }
    sync();
  });
</script>
